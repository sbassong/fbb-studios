---
import { getDla } from '../i18n/content';
import { getLangFromUrl } from '../i18n';

const lang = getLangFromUrl(Astro.url);
const dla = await getDla(lang);
const taglineParts = dla.tagline.split(/\s*·\s*/);

const followLabel = lang === 'fr'
  ? 'Suivre @FBB_STUDIOS sur Instagram'
  : 'Follow @FBB_STUDIOS on Instagram';
const watchLabel = lang === 'fr' ? 'Voir la bande-annonce' : 'Watch the trailer';
---
<section class="section section--bone dla-teaser" aria-labelledby="dla-title">
  <div class="container">
    <p class="eyebrow">A FBB Studios Production</p>
    <h2 id="dla-title" class="dla-teaser__title">{dla.title}</h2>
    <ul class="dot-list dla-teaser__tagline">
      {taglineParts.map((part) => <li>{part}</li>)}
    </ul>
    <p class="dla-teaser__status">{dla.statusLabel}</p>
    <p class="dla-teaser__logline">{dla.logline}</p>

    {dla.status === 'casting' && dla.castingEmail && (
      <p class="dla-teaser__casting-contact">
        <a href={`mailto:${dla.castingEmail}`}>{dla.castingEmail}</a>
      </p>
    )}

    {dla.status === 'post' && dla.trailerUrl && (
      <a class="button" href={dla.trailerUrl} rel="noopener" target="_blank">{watchLabel}</a>
    )}

    {dla.status === 'released' && dla.watchLinks.length > 0 && (
      <ul class="dla-teaser__watch">
        {dla.watchLinks.map((link) => (
          <li><a class="button" href={link.url} rel="noopener" target="_blank">{link.label}</a></li>
        ))}
      </ul>
    )}

    {dla.instagram && (
      <p class="dla-teaser__follow">
        <a href={dla.instagram} rel="noopener" target="_blank">
          {followLabel} →<span class="visually-hidden"> (opens in new tab)</span>
        </a>
      </p>
    )}
  </div>
</section>

<style>
  .dla-teaser__title {
    font-size: clamp(4.5rem, 10vw + 1rem, 11rem);
    letter-spacing: 0.04em;
    line-height: 1;
    margin-block: 0.25em 0.15em;
    color: var(--ink);
  }
  .dla-teaser__tagline {
    font-size: clamp(0.95rem, 0.9rem + 0.3vw, 1.15rem);
    color: var(--ink);
    opacity: 0.85;
    letter-spacing: 0.05em;
    margin-bottom: 2rem;
  }
  .dla-teaser__status {
    display: inline-block;
    border: 1px solid var(--gold-muted);
    color: var(--gold-muted);
    padding: 0.35rem 0.95rem;
    border-radius: 999px;
    font-size: 0.8rem;
    letter-spacing: var(--type-tracking-eyebrow);
    text-transform: uppercase;
    font-family: var(--font-display);
    font-weight: 600;
    margin-bottom: 2rem;
  }
  .dla-teaser__logline {
    font-size: clamp(1.15rem, 1rem + 0.6vw, 1.5rem);
    line-height: 1.5;
    max-width: 52ch;
    font-family: var(--font-display);
    font-style: italic;
    color: var(--ink);
    margin-bottom: 2.5rem;
  }
  .dla-teaser__casting-contact {
    margin-bottom: 1.5rem;
    font-family: var(--font-display);
    font-size: 1.05rem;
  }
  .dla-teaser__casting-contact a {
    color: var(--gold-muted);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
  }
  .dla-teaser__casting-contact a:hover { color: var(--ink); }
  .dla-teaser__follow { margin-top: 1.5rem; }
  .dla-teaser__follow a {
    color: var(--gold-muted);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
    font-family: var(--font-display);
    letter-spacing: 0.03em;
  }
  .dla-teaser__follow a:hover { color: var(--ink); }

  .dla-teaser__watch {
    list-style: none; padding: 0; display: flex; gap: 0.75rem; flex-wrap: wrap;
  }
</style>
