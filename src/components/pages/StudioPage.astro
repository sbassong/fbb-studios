---
import { getLangFromUrl, useTranslations } from '../../i18n';
import { getStudio, getDla } from '../../i18n/content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const studio = await getStudio(lang);
const dla = await getDla(lang);
const missionParas = studio.mission.split('\n\n');
const teamHeading = lang === 'fr' ? 'Équipe' : 'Team';
---
<section class="section section--ink">
  <div class="container container--narrow">
    <p class="eyebrow">{t.studioPage.eyebrow}</p>
    <h1>{t.studioPage.title}</h1>
    {missionParas.map((para) => <p class="studio-page__para">{para}</p>)}
  </div>
</section>

{studio.founders.length > 0 && (
  <section class="section section--bone">
    <div class="container">
      <p class="eyebrow">{teamHeading}</p>
      <ul class="studio-page__team">
        {studio.founders.map((person) => (
          <li class="studio-page__person">
            <h3>{person.name}</h3>
            <p class="studio-page__role">{person.role}</p>
            {person.bio && <p class="studio-page__bio">{person.bio}</p>}
          </li>
        ))}
      </ul>
    </div>
  </section>
)}

<section class={`section section--ink${studio.founders.length === 0 ? ' studio-page__contact--no-team' : ''}`}>
  <div class="container container--narrow">
    <p class="eyebrow">Contact</p>
    <h2 class="studio-page__contact-heading">{t.studioPage.contactHeading}</h2>
    <p>{t.studioPage.contactBody}</p>
    <dl class="studio-page__contact-list">
      {studio.contact.phone && (
        <div class="studio-page__contact-item">
          <dt>{t.studioPage.phoneLabel}</dt>
          <dd>
            <a href={`tel:${studio.contact.phone.replace(/[\s-]/g, '')}`}>{studio.contact.phone}</a>
          </dd>
        </div>
      )}
      {studio.contact.email && (
        <div class="studio-page__contact-item">
          <dt>{t.studioPage.emailLabel}</dt>
          <dd>
            <a href={`mailto:${studio.contact.email}`}>{studio.contact.email}</a>
          </dd>
        </div>
      )}
    </dl>
  </div>
</section>

<style>
  .studio-page__para {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 1rem + 0.6vw, 1.45rem);
    line-height: 1.5;
    margin-block: 1.25rem;
    max-width: 52ch;
  }
  .studio-page__team {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 2.5rem;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
  }
  .studio-page__person h3 { color: var(--ink); margin-bottom: 0.25rem; }
  .studio-page__role {
    color: var(--gold-muted);
    font-family: var(--font-display);
    letter-spacing: 0.04em;
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
  }
  .studio-page__bio { font-family: var(--font-display); font-size: 1rem; max-width: 32ch; }
  .studio-page__contact--no-team { padding-block-start: calc(var(--section-pad-y) / 2); }
  .studio-page__contact-heading { margin-block: 0.25em 1rem; color: var(--gold); }
  .studio-page__contact-list {
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .studio-page__contact-item { display: flex; flex-direction: column; gap: 0.2rem; }
  .studio-page__contact-item dt {
    font-size: 0.8rem;
    letter-spacing: var(--type-tracking-eyebrow);
    text-transform: uppercase;
    color: var(--gold-dim);
    font-family: var(--font-display);
  }
  .studio-page__contact-item dd {
    font-family: var(--font-display);
    font-size: 1.2rem;
  }
  .studio-page__contact-item a {
    color: var(--gold);
    text-decoration: none;
    border-bottom: 1px solid var(--gold-muted);
    padding-bottom: 1px;
  }
  .studio-page__contact-item a:hover { color: var(--bone); border-color: var(--bone); }
</style>
